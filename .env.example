# =====================================================================
# Cüzdan Koçu — environment variables
# Copy this file to `.env` and fill in real values for local dev.
# Day labels indicate when each variable is first consumed.
# =====================================================================

# ---------- Backend / FastAPI (Day 1) ----------
APP_ENV=development                          # development | production | test
APP_DEBUG=true                               # toggles verbose logs
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000       # comma-separated list

# ---------- Database (Day 1) ----------
# When running via docker-compose, host is the service name `postgres`.
# When running backend directly on host, use `localhost`.
DATABASE_URL=postgresql+psycopg://cuzdan:cuzdan@postgres:5432/cuzdan
POSTGRES_USER=cuzdan
POSTGRES_PASSWORD=cuzdan
POSTGRES_DB=cuzdan

# ---------- Auth / JWT (Day 1) ----------
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=change-me-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ---------- Object storage / MinIO (Day 1 service up; Day 4 backend integration) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000                    # docker network; localhost:9000 outside docker
MINIO_PUBLIC_ENDPOINT=http://localhost:9000  # signed URLs returned to browser
MINIO_BUCKET_RECEIPTS=receipts
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# ---------- LLM provider (Day 3+ agent; Day 4 OCR can reuse the same choice) ----------
# gemini = direct Google AI Studio API, openrouter = OpenRouter's OpenAI-compatible API.
LLM_PROVIDER=gemini

# Direct Gemini path.
GEMINI_API_KEY=                              # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter path. Keep empty unless LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=                          # https://openrouter.ai/keys
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Cüzdan Koçu

# ---------- Frontend / Next.js (Day 1) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Cüzdan Koçu
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-please-use-openssl-rand-hex-32
